# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local-only project notes (development log, scratch files)
/notes/

# 17Lands raw draft / game data dumps — multi-GB CSVs used for offline
# experimentation only. Aggregate JSON pulled from 17Lands' card_ratings
# endpoint lives in data/draft-stats/ and IS committed; the raw CSVs
# below are not.
/17Lands/
